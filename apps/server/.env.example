# OpenCode Zen API key (get one at https://opencode.ai/auth)
LLM_API_KEY=sk-...

# OpenAI-compatible base URL for OpenCode Zen.
# Use the API root only; do not append /chat/completions or /messages.
# Any other OpenAI-compatible endpoint (vLLM, LM Studio, LiteLLM, OpenAI cloud) works here too.
# LLM_BASE_URL=https://api.openai.com/v1
LLM_BASE_URL=https://opencode.ai/zen/go/v1

# Model identifier. See https://opencode.ai/docs/zen/ for the list.
# qwen3.5-plus routes through /chat/completions, which is what @ai-sdk/openai-compatible calls.
DEFAULT_MODEL=opencode-go/minimax-m2.7

# HTTP port (optional, defaults to 3000)
PORT=3000
